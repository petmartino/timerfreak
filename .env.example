# TimerFreak Development Environment Configuration Template
# Copy this file to .env and customize as needed:
#   cp .env.example .env

# =============================================================================
# SECURITY (Required for production - auto-generated for development)
# =============================================================================

# Flask secret key for session management and CSRF protection
# For production, generate a new one:
# python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-secret-key-change-in-production-1234567890abcdef

# Admin token for accessing /admin/stats endpoint
# For production, generate a new one:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_STATS_TOKEN=dev-admin-token-change-in-production

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask debug mode (true for development, false for production)
FLASK_DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Flask environment (development, production)
FLASK_ENV=development

# =============================================================================
# DATABASE (SQLite default - no configuration needed for development)
# =============================================================================

# For production with PostgreSQL/MySQL, uncomment and configure:
# DATABASE_URL=postgresql://user:password@localhost:5432/timerfreak
# SQLALCHEMY_DATABASE_URI=sqlite:///instance/timerfreak.db

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Development server host and port
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5001

# For production behind a proxy (nginx, Apache)
# Set these if running behind a reverse proxy
# PROXY_FIX_FOR=1
# PROXY_FIX_HOST=1
# PROXY_FIX_PREFIX=1

# =============================================================================
# OAUTH PROVIDERS (required for social login buttons)
# =============================================================================

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://yourdomain.com/auth/oauth/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
# Callback URL: https://yourdomain.com/auth/oauth/github/callback
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# NOTES
# =============================================================================
# - This .env file is for DEVELOPMENT only
# - NEVER commit .env with real secrets to version control
# - .env is already in .gitignore
# - For production, use secure environment variable management
#   (e.g., Docker secrets, AWS Secrets Manager, HashiCorp Vault)
